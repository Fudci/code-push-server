doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title CodePush Dashboard
    link(rel="preconnect" href="https://fonts.googleapis.com")
    link(rel="preconnect" href="https://fonts.gstatic.com" crossorigin)
    link(rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;600&display=swap")
    style.
      :root {
        --bg: #080c14;
        --bg-card: #0e1520;
        --bg-card2: #121c2a;
        --bg-input: #1a2535;
        --accent: #6366f1;
        --accent2: #8b5cf6;
        --green: #10b981;
        --yellow: #f59e0b;
        --red: #ef4444;
        --blue: #3b82f6;
        --orange: #f97316;
        --text: #f1f5f9;
        --text2: #94a3b8;
        --text3: #475569;
        --border: #1e293b;
        --border2: #243347;
        --grad: linear-gradient(135deg, #6366f1, #8b5cf6);
        --grad-green: linear-gradient(135deg, #10b981, #059669);
        --grad-red: linear-gradient(135deg, #ef4444, #dc2626);
        --grad-yellow: linear-gradient(135deg, #f59e0b, #d97706);
        --grad-blue: linear-gradient(135deg, #3b82f6, #2563eb);
        --shadow: 0 8px 32px rgba(0,0,0,0.5);
        --r: 16px;
        --r2: 10px;
        --r3: 6px;
      }
      * { margin: 0; padding: 0; box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body {
        font-family: 'Inter', sans-serif;
        background: var(--bg);
        color: var(--text);
        min-height: 100vh;
      }

      /* ===== SCROLLBAR ===== */
      ::-webkit-scrollbar { width: 6px; }
      ::-webkit-scrollbar-track { background: var(--bg); }
      ::-webkit-scrollbar-thumb { background: var(--border2); border-radius: 3px; }

      /* ===== AUTH ===== */
      #auth-overlay {
        position: fixed; inset: 0; z-index: 999;
        background: var(--bg);
        display: flex; align-items: center; justify-content: center;
      }
      .auth-wrap {
        width: 420px;
        animation: fadeUp 0.4s ease;
      }
      .auth-header {
        text-align: center; margin-bottom: 32px;
      }
      .auth-icon {
        width: 64px; height: 64px;
        background: var(--grad);
        border-radius: 18px;
        display: inline-flex; align-items: center; justify-content: center;
        font-size: 30px; margin-bottom: 16px;
        box-shadow: 0 8px 24px rgba(99,102,241,0.4);
      }
      .auth-header h1 { font-size: 24px; font-weight: 800; }
      .auth-header p { color: var(--text2); font-size: 14px; margin-top: 6px; }
      .auth-box {
        background: var(--bg-card);
        border: 1px solid var(--border2);
        border-radius: var(--r);
        padding: 32px;
        box-shadow: var(--shadow);
      }
      .form-group { margin-bottom: 16px; }
      .form-group label {
        display: block; font-size: 11px; font-weight: 700;
        color: var(--text2); margin-bottom: 8px;
        text-transform: uppercase; letter-spacing: 0.8px;
      }
      .form-group input {
        width: 100%; padding: 13px 16px;
        background: var(--bg-input);
        border: 1px solid var(--border2);
        border-radius: var(--r2);
        color: var(--text); font-family: 'Inter', sans-serif; font-size: 14px;
        outline: none; transition: border-color 0.2s, box-shadow 0.2s;
      }
      .form-group input:focus {
        border-color: var(--accent);
        box-shadow: 0 0 0 3px rgba(99,102,241,0.15);
      }
      .btn-login {
        width: 100%; padding: 14px;
        background: var(--grad);
        border: none; border-radius: var(--r2);
        color: white; font-family: 'Inter', sans-serif;
        font-size: 14px; font-weight: 700; cursor: pointer;
        transition: opacity 0.2s, transform 0.15s;
        box-shadow: 0 4px 16px rgba(99,102,241,0.4);
        margin-top: 4px;
      }
      .btn-login:hover { opacity: 0.9; transform: translateY(-1px); }
      .btn-login:active { transform: translateY(0); }
      .auth-error {
        color: var(--red); font-size: 13px;
        text-align: center; margin-top: 12px; display: none;
        background: rgba(239,68,68,0.08); border: 1px solid rgba(239,68,68,0.2);
        padding: 10px; border-radius: var(--r3);
      }

      /* ===== LAYOUT ===== */
      #app { display: none; }
      .topbar {
        display: flex; align-items: center; justify-content: space-between;
        padding: 14px 28px;
        background: rgba(14,21,32,0.95);
        backdrop-filter: blur(20px);
        border-bottom: 1px solid var(--border);
        position: sticky; top: 0; z-index: 100;
      }
      .topbar-left { display: flex; align-items: center; gap: 14px; }
      .topbar-icon {
        width: 36px; height: 36px;
        background: var(--grad);
        border-radius: 10px;
        display: flex; align-items: center; justify-content: center;
        font-size: 17px;
      }
      .topbar-title { font-size: 15px; font-weight: 800; }
      .topbar-sub { font-size: 11px; color: var(--text3); margin-top: 1px; }
      .topbar-right { display: flex; align-items: center; gap: 10px; }
      .badge-live {
        display: flex; align-items: center; gap: 6px;
        padding: 5px 12px;
        background: rgba(16,185,129,0.1);
        border: 1px solid rgba(16,185,129,0.25);
        border-radius: 100px; font-size: 11px; font-weight: 600; color: var(--green);
      }
      .badge-live::before {
        content: ''; width: 6px; height: 6px;
        background: var(--green); border-radius: 50%;
        animation: livePulse 1.5s infinite;
      }
      #user-label { font-size: 12px; color: var(--text3); }
      .btn-sm {
        padding: 7px 14px;
        background: transparent;
        border: 1px solid var(--border2);
        border-radius: var(--r2);
        color: var(--text2); font-size: 12px; font-weight: 600;
        cursor: pointer; transition: all 0.2s; font-family: 'Inter', sans-serif;
      }
      .btn-sm:hover { border-color: var(--accent); color: var(--accent); }
      .btn-sm.danger:hover { border-color: var(--red); color: var(--red); }
      .btn-sm.primary {
        background: rgba(99,102,241,0.12); border-color: rgba(99,102,241,0.3); color: var(--accent);
      }
      .btn-sm.primary:hover { background: rgba(99,102,241,0.22); }

      .main { padding: 28px; max-width: 1440px; margin: 0 auto; }

      /* ===== STATS GRID ===== */
      .stats-grid {
        display: grid; grid-template-columns: repeat(5, 1fr);
        gap: 14px; margin-bottom: 28px;
      }
      .stat-card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--r);
        padding: 20px 22px;
        position: relative; overflow: hidden;
        transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
        cursor: default;
      }
      .stat-card::after {
        content: ''; position: absolute;
        top: 0; left: 0; right: 0; height: 2px;
      }
      .stat-card.c-purple::after { background: var(--grad); }
      .stat-card.c-green::after { background: var(--grad-green); }
      .stat-card.c-yellow::after { background: var(--grad-yellow); }
      .stat-card.c-red::after { background: var(--grad-red); }
      .stat-card.c-blue::after { background: var(--grad-blue); }
      .stat-card:hover { transform: translateY(-3px); box-shadow: var(--shadow); border-color: var(--border2); }
      .stat-emoji { font-size: 20px; margin-bottom: 10px; }
      .stat-label { font-size: 11px; color: var(--text2); font-weight: 600; text-transform: uppercase; letter-spacing: 0.6px; }
      .stat-value { font-size: 30px; font-weight: 900; margin: 6px 0 3px; line-height: 1; }
      .stat-value.c-purple { color: #a5b4fc; }
      .stat-value.c-green { color: #6ee7b7; }
      .stat-value.c-yellow { color: #fcd34d; }
      .stat-value.c-red { color: #fca5a5; }
      .stat-value.c-blue { color: #93c5fd; }
      .stat-hint { font-size: 11px; color: var(--text3); }

      /* ===== SECTION HEADER ===== */
      .section-hdr {
        display: flex; align-items: center; justify-content: space-between;
        margin-bottom: 20px;
      }
      .section-hdr-left h2 { font-size: 16px; font-weight: 800; }
      .section-hdr-left p { font-size: 12px; color: var(--text2); margin-top: 3px; }
      .hdr-actions { display: flex; gap: 8px; align-items: center; }

      /* ===== APP CARD ===== */
      .apps-list { display: flex; flex-direction: column; gap: 20px; }
      .app-card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--r);
        overflow: hidden;
        transition: border-color 0.2s;
      }
      .app-card:hover { border-color: var(--border2); }
      .app-hdr {
        display: flex; align-items: center; justify-content: space-between;
        padding: 18px 24px; cursor: pointer; user-select: none;
      }
      .app-hdr-left { display: flex; align-items: center; gap: 14px; }
      .app-avatar {
        width: 44px; height: 44px;
        background: var(--grad);
        border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        font-size: 22px; flex-shrink: 0;
      }
      .app-name { font-size: 15px; font-weight: 800; }
      .app-meta { font-size: 12px; color: var(--text2); margin-top: 3px; }
      .chevron { color: var(--text3); font-size: 18px; transition: transform 0.3s; }
      .app-card.open .chevron { transform: rotate(180deg); }
      .app-body {
        display: none; padding: 0 24px 24px;
        border-top: 1px solid var(--border);
      }
      .app-card.open .app-body { display: block; }

      /* ===== DEPLOYMENT COLUMNS ===== */
      .dep-cols { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-top: 20px; }
      .dep-panel {
        background: var(--bg);
        border: 1px solid var(--border);
        border-radius: var(--r2);
        overflow: hidden;
      }
      .dep-panel-hdr {
        display: flex; align-items: center; justify-content: space-between;
        padding: 14px 18px;
        border-bottom: 1px solid var(--border);
        background: var(--bg-card2);
      }
      .dep-panel-name { font-size: 13px; font-weight: 800; }
      .dep-badge {
        padding: 3px 10px; border-radius: 100px;
        font-size: 10px; font-weight: 700; letter-spacing: 0.5px; text-transform: uppercase;
      }
      .dep-badge.prod { background: rgba(99,102,241,0.15); color: #a5b4fc; border: 1px solid rgba(99,102,241,0.3); }
      .dep-badge.stag { background: rgba(245,158,11,0.15); color: #fcd34d; border: 1px solid rgba(245,158,11,0.3); }
      .dep-panel-body { padding: 16px 18px; }

      /* ===== DEP KEY ===== */
      .dep-key-row {
        display: flex; align-items: center; gap: 8px;
        margin-bottom: 14px;
      }
      .dep-key-label { font-size: 11px; color: var(--text3); font-weight: 600; text-transform: uppercase; white-space: nowrap; }
      .dep-key-val {
        font-family: 'JetBrains Mono', monospace;
        font-size: 10px; color: var(--text2);
        background: rgba(255,255,255,0.04);
        padding: 5px 10px; border-radius: var(--r3);
        border: 1px solid var(--border);
        flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
      }

      /* ===== METRICS ===== */
      .metrics-bar {
        display: grid; grid-template-columns: repeat(4,1fr);
        gap: 6px; margin-bottom: 16px;
      }
      .m-cell {
        text-align: center;
        background: rgba(255,255,255,0.03);
        border: 1px solid var(--border);
        border-radius: var(--r3);
        padding: 10px 6px;
      }
      .m-num { font-size: 18px; font-weight: 900; line-height: 1; }
      .m-num.green { color: #6ee7b7; }
      .m-num.blue { color: #93c5fd; }
      .m-num.yellow { color: #fcd34d; }
      .m-num.red { color: #fca5a5; }
      .m-lbl { font-size: 9px; color: var(--text3); margin-top: 4px; text-transform: uppercase; font-weight: 600; letter-spacing: 0.4px; }

      /* ===== RELEASE TIMELINE ===== */
      .releases-hdr {
        font-size: 11px; font-weight: 700; color: var(--text2);
        text-transform: uppercase; letter-spacing: 0.6px;
        margin-bottom: 10px;
        display: flex; align-items: center; justify-content: space-between;
      }
      .releases-hdr span { color: var(--text3); font-weight: 400; text-transform: none; letter-spacing: 0; font-size: 10px; }
      .timeline { display: flex; flex-direction: column; gap: 0; }
      .timeline-item {
        display: flex; gap: 12px;
        position: relative;
      }
      .tl-left {
        display: flex; flex-direction: column; align-items: center;
        flex-shrink: 0; width: 28px;
      }
      .tl-dot {
        width: 28px; height: 28px;
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        font-size: 12px; font-weight: 800;
        flex-shrink: 0; z-index: 1;
        border: 2px solid var(--border);
        background: var(--bg-card2);
        color: var(--text2);
      }
      .tl-dot.latest {
        background: var(--grad);
        border-color: #6366f1;
        color: white;
        box-shadow: 0 0 12px rgba(99,102,241,0.5);
      }
      .tl-line {
        flex: 1; width: 2px;
        background: var(--border);
        margin: 4px auto;
        min-height: 12px;
      }
      .tl-right {
        flex: 1; padding-bottom: 14px;
      }
      .tl-card {
        background: var(--bg-card2);
        border: 1px solid var(--border);
        border-radius: var(--r2);
        padding: 12px 14px;
        transition: border-color 0.2s;
      }
      .tl-card:hover { border-color: var(--border2); }
      .tl-card.is-latest { border-color: rgba(99,102,241,0.35); }
      .tl-card-hdr {
        display: flex; align-items: center; justify-content: space-between;
        margin-bottom: 8px; gap: 8px; flex-wrap: wrap;
      }
      .tl-label-row { display: flex; align-items: center; gap: 6px; }
      .tl-label {
        font-family: 'JetBrains Mono', monospace;
        font-size: 12px; font-weight: 700;
        color: #a5b4fc;
        background: rgba(99,102,241,0.15);
        padding: 3px 8px; border-radius: 4px;
        border: 1px solid rgba(99,102,241,0.25);
      }
      .tl-label.latest-lbl {
        background: var(--grad);
        color: white; border-color: transparent;
      }
      .badge-mandatory {
        padding: 2px 7px; border-radius: 4px;
        font-size: 9px; font-weight: 700; text-transform: uppercase;
        background: rgba(239,68,68,0.15); color: #fca5a5;
        border: 1px solid rgba(239,68,68,0.2);
      }
      .badge-latest {
        padding: 2px 7px; border-radius: 4px;
        font-size: 9px; font-weight: 700; text-transform: uppercase;
        background: rgba(99,102,241,0.15); color: #a5b4fc;
        border: 1px solid rgba(99,102,241,0.2);
      }
      .tl-meta-row {
        display: flex; align-items: center; gap: 10px; flex-wrap: wrap;
      }
      /* SIZE PILL — highlight utama */
      .size-pill {
        display: inline-flex; align-items: center; gap: 5px;
        padding: 4px 10px;
        background: rgba(16,185,129,0.1);
        border: 1px solid rgba(16,185,129,0.25);
        border-radius: 100px;
        font-size: 12px; font-weight: 700; color: #6ee7b7;
      }
      .size-pill .size-icon { font-size: 10px; }
      .tl-time { font-size: 11px; color: var(--text3); }
      .tl-version {
        font-family: 'JetBrains Mono', monospace;
        font-size: 10px; color: var(--text3);
        background: rgba(255,255,255,0.04);
        padding: 2px 7px; border-radius: 3px;
        border: 1px solid var(--border);
      }
      .tl-desc {
        font-size: 12px; color: var(--text2);
        line-height: 1.5;
        padding: 8px 10px;
        background: rgba(255,255,255,0.02);
        border: 1px solid var(--border);
        border-radius: var(--r3);
        margin-top: 8px;
        font-style: italic;
      }
      .tl-desc.no-desc { color: var(--text3); font-style: italic; }
      .tl-changes {
        margin-top: 8px;
        display: flex; flex-direction: column; gap: 4px;
      }
      .change-line {
        display: flex; align-items: flex-start; gap: 8px;
        font-size: 12px; color: var(--text2);
      }
      .change-bullet { color: var(--accent); font-weight: 700; flex-shrink: 0; }
      .no-release {
        text-align: center; padding: 28px;
        color: var(--text3); font-size: 12px;
      }
      .no-release .icon { font-size: 28px; margin-bottom: 8px; }

      /* ===== LOADING / EMPTY ===== */
      .load-wrap { display: flex; align-items: center; justify-content: center; padding: 60px; gap: 12px; }
      .spinner {
        width: 30px; height: 30px;
        border: 3px solid var(--border2);
        border-top-color: var(--accent);
        border-radius: 50%;
        animation: spin 0.7s linear infinite;
        flex-shrink: 0;
      }
      .empty-page { text-align: center; padding: 80px; color: var(--text3); }
      .empty-page .icon { font-size: 48px; margin-bottom: 14px; }
      .empty-page p { font-size: 14px; line-height: 1.6; }

      /* ===== TOAST ===== */
      #toast {
        position: fixed; bottom: 24px; right: 24px; z-index: 9999;
        padding: 12px 18px;
        background: var(--bg-card);
        border: 1px solid var(--border2);
        border-radius: var(--r2);
        font-size: 13px; font-weight: 600;
        box-shadow: var(--shadow);
        transform: translateY(80px); opacity: 0;
        transition: all 0.3s; pointer-events: none;
      }
      #toast.show { transform: translateY(0); opacity: 1; }
      #toast.success { border-color: rgba(16,185,129,0.4); color: var(--green); }
      #toast.error { border-color: rgba(239,68,68,0.4); color: var(--red); }
      #toast.info { border-color: rgba(99,102,241,0.4); color: #a5b4fc; }

      /* ===== ANIMATIONS ===== */
      @keyframes fadeUp { from { opacity:0; transform:translateY(24px); } to { opacity:1; transform:translateY(0); } }
      @keyframes spin { to { transform:rotate(360deg); } }
      @keyframes livePulse { 0%,100%{opacity:1;} 50%{opacity:0.3;} }
      @keyframes shimmer {
        0% { background-position: -400px 0; }
        100% { background-position: 400px 0; }
      }

      /* ===== RESPONSIVE ===== */
      @media (max-width: 900px) {
        .stats-grid { grid-template-columns: repeat(2,1fr); }
        .dep-cols { grid-template-columns: 1fr; }
        .topbar { padding: 12px 16px; }
        .main { padding: 16px; }
      }
      @media (max-width: 500px) {
        .stats-grid { grid-template-columns: 1fr 1fr; }
        .metrics-bar { grid-template-columns: repeat(2,1fr); }
      }

  body
    //- AUTH OVERLAY
    #auth-overlay
      .auth-wrap
        .auth-header
          .auth-icon 🚀
          h1 CodePush Dashboard
          p Monitor OTA releases secara real-time
        .auth-box
          form#login-form
            .form-group
              label Email / Username
              input#login-email(type="text" placeholder="admin@email.com" autocomplete="username")
            .form-group
              label Password
              input#login-password(type="password" placeholder="••••••••" autocomplete="current-password")
            button.btn-login(type="submit") Masuk ke Dashboard →
          p.auth-error#auth-error ❌ Login gagal. Periksa email & password kamu.

    //- MAIN APP
    #app
      .topbar
        .topbar-left
          .topbar-icon 🚀
          div
            .topbar-title CodePush Dashboard
            .topbar-sub OTA Update Monitor
        .topbar-right
          .badge-live Server Live
          span#user-label
          button.btn-sm.primary#btn-refresh ↻ Refresh
          button.btn-sm.danger#btn-logout Logout

      .main
        //- GLOBAL STATS
        .stats-grid
          .stat-card.c-purple
            .stat-emoji 📦
            .stat-label Total Apps
            .stat-value.c-purple#stat-apps —
            .stat-hint Terdaftar di server
          .stat-card.c-green
            .stat-emoji 📲
            .stat-label Active Installs
            .stat-value.c-green#stat-active —
            .stat-hint Device pakai update terbaru
          .stat-card.c-blue
            .stat-emoji ⬇️
            .stat-label Total Downloads
            .stat-value.c-blue#stat-downloads —
            .stat-hint Semua versi digabung
          .stat-card.c-yellow
            .stat-emoji ✅
            .stat-label Installed
            .stat-value.c-yellow#stat-installed —
            .stat-hint Berhasil terinstall
          .stat-card.c-red
            .stat-emoji ❌
            .stat-label Failures
            .stat-value.c-red#stat-failures —
            .stat-hint Gagal apply update

        //- APPS & DEPLOYMENTS
        .section-hdr
          .section-hdr-left
            h2 📱 Apps & Release History
            p Ukuran bundle, deskripsi perubahan, dan metrics per deployment
          .hdr-actions
            span#last-updated(style="font-size:11px;color:var(--text3)") —
        
        #apps-container
          .load-wrap
            .spinner
            span(style="color:var(--text3);font-size:13px") Memuat data...

    #toast

    script.
      const API = '';
      let authToken = '';
      let globalStats = { active: 0, downloads: 0, installed: 0, failures: 0 };

      // ===== UTILS =====
      function showToast(msg, type = 'success') {
        const t = document.getElementById('toast');
        t.textContent = msg;
        t.className = 'show ' + type;
        clearTimeout(t._tid);
        t._tid = setTimeout(() => { t.className = ''; }, 3200);
      }

      function timeAgo(ts) {
        if (!ts) return '—';
        const s = Math.floor((Date.now() - new Date(ts)) / 1000);
        if (s < 60) return s + ' detik lalu';
        if (s < 3600) return Math.floor(s/60) + ' menit lalu';
        if (s < 86400) return Math.floor(s/3600) + ' jam lalu';
        if (s < 604800) return Math.floor(s/86400) + ' hari lalu';
        return new Date(ts).toLocaleDateString('id-ID', { day:'numeric', month:'short', year:'numeric' });
      }

      function bytesHuman(b) {
        if (!b || b === 0) return '—';
        if (b < 1024) return b + ' B';
        if (b < 1048576) return (b/1024).toFixed(1) + ' KB';
        return (b/1048576).toFixed(2) + ' MB';
      }

      function sizeColor(b) {
        if (!b) return '';
        const mb = b / 1048576;
        if (mb < 0.5) return 'color:#6ee7b7';   // hijau < 500 KB
        if (mb < 2) return 'color:#fcd34d';       // kuning < 2 MB
        return 'color:#fca5a5';                    // merah >= 2 MB
      }

      async function apiFetch(path) {
        const r = await fetch(API + path, {
          headers: { Authorization: 'Bearer ' + authToken }
        });
        if (!r.ok) throw new Error('HTTP ' + r.status);
        return r.json();
      }

      function parseChanges(description) {
        if (!description) return null;
        // detect bullet list with - or •
        const lines = description.split('\n').map(l => l.trim()).filter(Boolean);
        if (lines.length > 1) return lines;
        return null;
      }

      // ===== AUTH =====
      function checkAuth() {
        const token = sessionStorage.getItem('cp_auth');
        if (token) {
          authToken = token;
          document.getElementById('auth-overlay').style.display = 'none';
          document.getElementById('app').style.display = 'block';
          loadDashboard();
        }
      }

      document.getElementById('login-form').addEventListener('submit', async (e) => {
        e.preventDefault();
        const account = document.getElementById('login-email').value.trim();
        const password = document.getElementById('login-password').value;
        const errEl = document.getElementById('auth-error');
        errEl.style.display = 'none';
        const btn = e.target.querySelector('.btn-login');
        btn.textContent = 'Masuk...'; btn.disabled = true;
        try {
          const r = await fetch(API + '/auth/login', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: 'account=' + encodeURIComponent(account) + '&password=' + encodeURIComponent(password)
          });
          const data = await r.json();
          if (data.status === 'OK') {
            authToken = data.results.tokens;
            sessionStorage.setItem('cp_auth', authToken);
            document.getElementById('auth-overlay').style.display = 'none';
            document.getElementById('app').style.display = 'block';
            document.getElementById('user-label').textContent = account;
            loadDashboard();
          } else {
            errEl.style.display = 'block';
          }
        } catch(err) {
          errEl.style.display = 'block';
        }
        btn.textContent = 'Masuk ke Dashboard →'; btn.disabled = false;
      });

      document.getElementById('btn-logout').addEventListener('click', () => {
        sessionStorage.removeItem('cp_auth');
        location.reload();
      });
      document.getElementById('btn-refresh').addEventListener('click', loadDashboard);

      // ===== LOAD DASHBOARD =====
      async function loadDashboard() {
        globalStats = { active: 0, downloads: 0, installed: 0, failures: 0 };
        ['stat-apps','stat-active','stat-downloads','stat-installed','stat-failures']
          .forEach(id => { document.getElementById(id).textContent = '—'; });

        const container = document.getElementById('apps-container');
        container.innerHTML = '<div class="load-wrap"><div class="spinner"></div><span style="color:var(--text3);font-size:13px">Memuat data...</span></div>';

        try {
          const data = await apiFetch('/apps');
          const apps = data.apps || [];
          document.getElementById('stat-apps').textContent = apps.length;

          if (apps.length === 0) {
            container.innerHTML = '<div class="empty-page"><div class="icon">📭</div><p>Belum ada app terdaftar.<br><code style="font-size:12px">code-push app add</code> dulu ya.</p></div>';
            return;
          }

          const list = document.createElement('div');
          list.className = 'apps-list';
          container.innerHTML = '';
          container.appendChild(list);

          for (const app of apps) {
            const card = await buildAppCard(app);
            list.appendChild(card);
          }

          document.getElementById('stat-active').textContent = globalStats.active.toLocaleString('id-ID');
          document.getElementById('stat-downloads').textContent = globalStats.downloads.toLocaleString('id-ID');
          document.getElementById('stat-installed').textContent = globalStats.installed.toLocaleString('id-ID');
          document.getElementById('stat-failures').textContent = globalStats.failures.toLocaleString('id-ID');

          const now = new Date().toLocaleTimeString('id-ID');
          document.getElementById('last-updated').textContent = 'Terakhir diperbarui: ' + now;
          showToast('✅ Data berhasil dimuat', 'success');
        } catch(err) {
          container.innerHTML = '<div class="empty-page"><div class="icon">❌</div><p>Gagal memuat data.<br><small style="color:var(--text3)">' + err.message + '</small></p></div>';
          showToast('❌ Gagal memuat: ' + err.message, 'error');
        }
      }

      async function buildAppCard(app) {
        const card = document.createElement('div');
        card.className = 'app-card open';
        const osIcon = (app.os === 1 || app.os === 'iOS') ? '🍎' : (app.os === 2 || app.os === 'Android') ? '🤖' : '💻';
        const osName = (app.os === 1 || app.os === 'iOS') ? 'iOS' : (app.os === 2 || app.os === 'Android') ? 'Android' : 'Windows';
        const depCount = (app.deployments || []).length;
        const bodyId = 'body-' + app.name.replace(/\W/g,'_');

        card.innerHTML = `
          <div class="app-hdr" onclick="toggleCard(this)">
            <div class="app-hdr-left">
              <div class="app-avatar">${osIcon}</div>
              <div>
                <div class="app-name">${app.name}</div>
                <div class="app-meta">${osName} &nbsp;·&nbsp; ${depCount} deployment</div>
              </div>
            </div>
            <span class="chevron">⌄</span>
          </div>
          <div class="app-body">
            <div class="dep-cols" id="${bodyId}">
              <div class="load-wrap"><div class="spinner"></div></div>
            </div>
          </div>
        `;

        loadDeployments(app.name, bodyId);
        return card;
      }

      function toggleCard(hdr) {
        const card = hdr.closest('.app-card');
        card.classList.toggle('open');
      }

      async function loadDeployments(appName, containerId) {
        const container = document.getElementById(containerId);
        try {
          const data = await apiFetch('/apps/' + encodeURIComponent(appName) + '/deployments');
          const deps = data.deployments || [];
          if (deps.length === 0) {
            container.innerHTML = '<div class="no-release"><div class="icon">📭</div><p>Belum ada deployment</p></div>';
            return;
          }

          container.innerHTML = '';
          for (const dep of deps) {
            const panel = await buildDepPanel(appName, dep);
            container.appendChild(panel);
          }
        } catch(err) {
          container.innerHTML = '<div class="no-release">Gagal memuat deployment: ' + err.message + '</div>';
        }
      }

      async function buildDepPanel(appName, dep) {
        const panel = document.createElement('div');
        panel.className = 'dep-panel';
        const isProd = dep.name.toLowerCase().includes('prod');
        const badgeClass = isProd ? 'prod' : 'stag';
        const fullKey = dep.key || dep.deployment_key || '';
        const keyShort = fullKey.length > 36 ? fullKey.substring(0, 36) + '…' : fullKey;

        // Fetch metrics + history in parallel
        let metricsHtml = '';
        let historyHtml = '';
        try {
          const [mData, hData] = await Promise.all([
            apiFetch('/apps/' + encodeURIComponent(appName) + '/deployments/' + encodeURIComponent(dep.name) + '/metrics'),
            apiFetch('/apps/' + encodeURIComponent(appName) + '/deployments/' + encodeURIComponent(dep.name) + '/history')
          ]);
          metricsHtml = buildMetricsHtml(mData.metrics || {});
          historyHtml = buildHistoryHtml(hData.history || []);
        } catch(e) {
          metricsHtml = '<div class="no-release" style="padding:10px">Gagal muat metrics</div>';
          historyHtml = '<div class="no-release" style="padding:10px">Gagal muat history</div>';
        }

        panel.innerHTML = `
          <div class="dep-panel-hdr">
            <span class="dep-panel-name">${dep.name}</span>
            <span class="dep-badge ${badgeClass}">${dep.name}</span>
          </div>
          <div class="dep-panel-body">
            <div class="dep-key-row">
              <span class="dep-key-label">🔑 Key</span>
              <span class="dep-key-val" title="${fullKey}">${keyShort}</span>
            </div>
            ${metricsHtml}
            ${historyHtml}
          </div>
        `;
        return panel;
      }

      function buildMetricsHtml(metrics) {
        let active = 0, downloaded = 0, installed = 0, failed = 0;
        for (const v of Object.values(metrics)) {
          active += (v.active || 0);
          downloaded += (v.downloaded || 0);
          installed += (v.installed || 0);
          failed += (v.failed || 0);
        }
        globalStats.active += active;
        globalStats.downloads += downloaded;
        globalStats.installed += installed;
        globalStats.failures += failed;
        return `
          <div class="metrics-bar">
            <div class="m-cell"><div class="m-num green">${active.toLocaleString('id-ID')}</div><div class="m-lbl">Active</div></div>
            <div class="m-cell"><div class="m-num blue">${downloaded.toLocaleString('id-ID')}</div><div class="m-lbl">DL</div></div>
            <div class="m-cell"><div class="m-num yellow">${installed.toLocaleString('id-ID')}</div><div class="m-lbl">Installed</div></div>
            <div class="m-cell"><div class="m-num red">${failed.toLocaleString('id-ID')}</div><div class="m-lbl">Failed</div></div>
          </div>
        `;
      }

      function buildHistoryHtml(history) {
        // Newest first, show last 8
        const sorted = [...history].reverse().slice(0, 8);
        if (sorted.length === 0) {
          return `
            <div class="releases-hdr">Release History</div>
            <div class="no-release">
              <div class="icon">🕳️</div>
              <p>Belum ada release yang pernah dipush</p>
            </div>
          `;
        }

        let tl = '<div class="releases-hdr">Release History <span>8 terbaru, terlama → terbaru</span></div><div class="timeline">';

        sorted.forEach((h, idx) => {
          const isLatest = idx === 0;
          const label = h.label || '?';
          const ts = timeAgo(h.uploadTime);
          const tsExact = h.uploadTime ? new Date(h.uploadTime).toLocaleString('id-ID') : '—';
          const sizeBytes = h.size || 0;
          const sizeStr = bytesHuman(sizeBytes);
          const sizeStyle = sizeColor(sizeBytes);
          const desc = h.description || '';
          const appVer = h.appVersion || '—';
          const isMandatory = h.isMandatoryUpdate;
          const changes = parseChanges(desc);

          // Size pill — core feature yang diminta
          const sizePillHtml = sizeBytes > 0 ? `
            <div class="size-pill" title="${sizeBytes.toLocaleString()} bytes">
              <span class="size-icon">📦</span>
              <span style="${sizeStyle};font-size:12px;font-weight:800">${sizeStr}</span>
            </div>` : `<div class="size-pill" style="opacity:0.4"><span class="size-icon">📦</span> —</div>`;

          // Description / changes
          let descHtml = '';
          if (changes && changes.length > 1) {
            const lines = changes.map(l => {
              const clean = l.replace(/^[-•*]\s*/, '');
              return `<div class="change-line"><span class="change-bullet">→</span><span>${clean}</span></div>`;
            }).join('');
            descHtml = `<div class="tl-changes">${lines}</div>`;
          } else if (desc) {
            descHtml = `<div class="tl-desc">"${desc}"</div>`;
          } else {
            descHtml = `<div class="tl-desc no-desc">(Tidak ada deskripsi perubahan)</div>`;
          }

          tl += `
            <div class="timeline-item">
              <div class="tl-left">
                <div class="tl-dot ${isLatest ? 'latest' : ''}">${isLatest ? '★' : sorted.length - idx}</div>
                ${idx < sorted.length - 1 ? '<div class="tl-line"></div>' : ''}
              </div>
              <div class="tl-right">
                <div class="tl-card ${isLatest ? 'is-latest' : ''}">
                  <div class="tl-card-hdr">
                    <div class="tl-label-row">
                      <span class="tl-label ${isLatest ? 'latest-lbl' : ''}">${label}</span>
                      ${isLatest ? '<span class="badge-latest">LATEST</span>' : ''}
                      ${isMandatory ? '<span class="badge-mandatory">WAJIB</span>' : ''}
                    </div>
                    <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap">
                      ${sizePillHtml}
                    </div>
                  </div>
                  <div class="tl-meta-row">
                    <span class="tl-version">v${appVer}</span>
                    <span class="tl-time" title="${tsExact}">🕐 ${ts}</span>
                  </div>
                  ${descHtml}
                </div>
              </div>
            </div>
          `;
        });

        tl += '</div>';
        return tl;
      }

      // ===== INIT =====
      checkAuth();
